{{!
	Stella Nova — plantilla raíz. Cumple SkinRenderFidelity: emite TODAS
	las data keys estándar de SkinMustache 1.43 aunque no las estilice, no
	recorta ni reestructura el HTML de extensiones, y respeta los puntos de
	inyección (html-after-content, indicadores, catlinks, html-subtitle).

	LightnCandy (Mustache de MW): se usan SECCIONES de un solo segmento
	anidadas (rutas con punto en aperturas/cierres rompen al combinarse con
	parciales); las interpolaciones con ruta-punto sí son válidas. No poner
	sintaxis de plantilla dentro de comentarios: el primer cierre la trunca.

	Datos propios (SkinStellaNova::getTemplateData):
	  is-sn-fullscreen · sn-isotype{href,is-override,html-override,svg,
	  svg-icon} · sn-identity · sn-prefs{…} · sn-chrome{notice,sidebar,
	  footer}{is-published,html}
}}
{{{html-headelement}}}
<a class="sn-skip" href="#sn-content">{{msg-stellanova-skip-to-content}}</a>
{{^is-sn-fullscreen}}<a class="sn-skip" href="#sn-nav">{{msg-stellanova-skip-to-nav}}</a>{{/is-sn-fullscreen}}

{{#is-sn-fullscreen}}
{{!	ExperimentalCanvas: la página posee el viewport. La única
	afordancia persistente es el isotipo Casiopea en la esquina
	superior izquierda; al activarse abre un modal único que reúne
	—en secciones— Portada, Búsqueda, Navegación, Esta página,
	Cuenta y Preferencias. Sin "salir de pantalla completa" — el
	modal mismo es la salida (los enlaces de Portada/Navegación
	salen del canvas). }}
<main id="sn-content" class="sn-canvas" tabindex="-1">
	<div class="sn-fs-bar">
		<div class="sn-md sn-md-fs sn-fs-md">
			<button type="button" class="sn-fs-trigger" aria-expanded="false"
				aria-haspopup="dialog" data-sn-menu
				title="{{msg-stellanova-menu}}" aria-label="{{msg-stellanova-menu}}">
				{{#sn-isotype}}<span class="sn-fs-glyph">{{{svg-icon}}}</span>{{/sn-isotype}}
			</button>
			<div class="sn-menu-list sn-fs-menu" aria-label="{{msg-stellanova-menu}}">
				<header class="sn-modal-head">
					<h2 class="sn-modal-title">{{msg-stellanova-menu}}</h2>
					<button type="button" class="sn-modal-x" data-sn-menu-close
						aria-label="{{msg-stellanova-close}}" title="{{msg-stellanova-close}}">
						<svg class="sn-i" aria-hidden="true" width="20" height="20" viewBox="0 0 24 24"><use href="#sn-i-x"/></svg>
					</button>
				</header>
				<div class="sn-modal-body">
					{{!	Orden: Buscador (full-row, max-width interno 30em)
						→ Navegación (con Portada incorporada arriba)
						→ Esta página → Usuario. En pantallas grandes
						(≥ 64rem) el body usa 3 columnas; el buscador
						atraviesa las 3 como cabecera del modal. }}

					{{#data-search-box}}
					<section class="sn-fs-sec sn-fs-sec--search" aria-labelledby="sn-fs-h-search">
						<h3 id="sn-fs-h-search" class="sn-fs-h">{{msg-stellanova-search}}</h3>
						<form class="sn-fs-search" role="search" action="{{form-action}}"
							id="searchform" aria-label="{{msg-searchbutton}}">
							{{{html-input}}}
							<input type="hidden" name="title" value="{{page-title}}">
							<button type="submit" class="sn-iconbtn"
								title="{{msg-searchbutton}}" aria-label="{{msg-searchbutton}}">
								<svg class="sn-i" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24"><use href="#sn-i-search"/></svg>
							</button>
						</form>
					</section>
					{{/data-search-box}}

					{{!	Navegación: la Portada va como primer link, antes
						de los subgrupos del MediaWiki:Sidebar (cada
						portlet aporta su label como h4 y sus items como
						enlaces inline-comma). }}
					<section class="sn-fs-sec" aria-labelledby="sn-fs-h-nav">
						<h3 id="sn-fs-h-nav" class="sn-fs-h">{{msg-stellanova-nav}}</h3>
						<ul class="sn-fs-links">
							<li class="mw-list-item"><a href="{{sn-isotype.href}}">{{msg-stellanova-mainpage}}</a></li>
						</ul>
						{{#sn-has-sitenav}}
						{{#sn-sitenav}}
						<div class="sn-fs-group">
							{{#label}}<h4 class="sn-fs-subh">{{.}}</h4>{{/label}}
							<ul class="sn-fs-links">{{{html-items}}}</ul>
						</div>
						{{/sn-sitenav}}
						{{/sn-has-sitenav}}
					</section>

					<section class="sn-fs-sec" aria-labelledby="sn-fs-h-page">
						<h3 id="sn-fs-h-page" class="sn-fs-h">{{msg-stellanova-thispage}}</h3>
						<ul class="sn-fs-pills">
							{{#sn-edit}}<li class="mw-list-item"><a href="{{href}}">{{label}}</a></li>{{/sn-edit}}
							{{#sn-editcode}}<li class="mw-list-item"><a href="{{href}}">{{label}}</a></li>{{/sn-editcode}}
							{{#data-portlets}}{{#data-namespaces}}{{{html-items}}}{{/data-namespaces}}{{/data-portlets}}
							{{#sn-has-pageviews}}{{#sn-pageviews}}<li id="{{id}}" class="{{class}}">{{{html}}}</li>{{/sn-pageviews}}{{/sn-has-pageviews}}
							{{#data-portlets}}{{#data-actions}}{{{html-items}}}{{/data-actions}}{{/data-portlets}}
							{{#data-portlets}}{{#data-variants}}{{{html-items}}}{{/data-variants}}{{/data-portlets}}
						</ul>
					</section>

					{{#data-portlets}}
					{{#data-user-menu}}
					<section class="sn-fs-sec" aria-labelledby="sn-fs-h-user">
						<h3 id="sn-fs-h-user" class="sn-fs-h">{{msg-stellanova-user}}</h3>
						<ul class="sn-fs-pills">{{{html-items}}}</ul>
					</section>
					{{/data-user-menu}}
					{{/data-portlets}}
				</div>
			</div>
		</div>
	</div>

	{{!	El wrapper del cuerpo lleva además `.sn-body` y `.mw-body-content`
		para heredar TODOS los estilos editoriales del skin (tablas,
		listas, .plantilla, poem, blockquote, TOC, etc.) sin duplicar
		selectores con `.sn-canvas-body`. }}
	<div class="sn-canvas-body sn-body mw-body-content">
		{{{html-body-content}}}
	</div>
</main>
{{/is-sn-fullscreen}}

{{^is-sn-fullscreen}}
<div class="sn-app">
	<header class="sn-header" role="banner">
		<div class="sn-header-bar">
			{{!	Marca + navegación, juntas a la izquierda: el isotipo
				(logotipo "Casiopea" + constelación, SVG colorizable →
				portada; el wordmark va dentro, sin texto aparte) pegado al
				menú hamburguesa de navegación del sitio. El isotipo trae
				DOS variantes inline: el wordmark (desktop) y el glifo
				cuadrado compacto (mobile); CSS decide cuál se muestra
				según el viewport — mismo enlace, misma etiqueta. }}
			<div class="sn-brandnav">
				<a class="sn-isotype" href="{{sn-isotype.href}}"
					aria-label="{{msg-stellanova-home}}" title="{{msg-stellanova-home}}">
					{{#sn-isotype}}
					{{#is-override}}{{{html-override}}}{{/is-override}}
					{{^is-override}}<span class="sn-isotype-full">{{{svg}}}</span><span class="sn-isotype-compact">{{{svg-icon}}}</span>{{/is-override}}
					{{/sn-isotype}}
				</a>

				{{!	Navegación del SITIO (Escuela/Wiki/Navegación…). La caja
					de herramientas ("Herramientas y más") vive en el pie. }}
				{{#sn-has-sitenav}}
				<div class="sn-md sn-sitenav">
					<button type="button" class="sn-md-trigger sn-md-icononly" aria-expanded="false"
						aria-haspopup="true" data-sn-menu
						title="{{msg-stellanova-nav}}" aria-label="{{msg-stellanova-nav}}">
						<svg class="sn-i" aria-hidden="true" width="20" height="20" viewBox="0 0 24 24"><use href="#sn-i-menu"/></svg>
						<svg class="sn-i sn-md-caret" aria-hidden="true" width="14" height="14" viewBox="0 0 24 24"><use href="#sn-i-chevron-down"/></svg>
					</button>
					<div class="sn-menu-list sn-megamenu" aria-label="{{msg-stellanova-sidebar}}">
						<header class="sn-modal-head">
							<h2 class="sn-modal-title">{{msg-stellanova-nav}}</h2>
							<button type="button" class="sn-modal-x" data-sn-menu-close
								aria-label="{{msg-stellanova-close}}" title="{{msg-stellanova-close}}">
								<svg class="sn-i" aria-hidden="true" width="20" height="20" viewBox="0 0 24 24"><use href="#sn-i-x"/></svg>
							</button>
						</header>
						<div class="sn-modal-body">
							{{#sn-sitenav}}
							<section class="sn-mm-sec">
								{{#label}}<h2 class="sn-mm-h">{{.}}</h2>{{/label}}
								<ul>{{{html-items}}}</ul>
							</section>
							{{/sn-sitenav}}
						</div>
					</div>
				</div>
				{{/sn-has-sitenav}}
			</div>

			{{!	Buscador. Desktop: input visible inline. Compact viewport:
				el input se oculta y aparece un trigger (lupa) que abre el
				mismo form como modal (spec TransientPanel) — el input y
				el submit son los MISMOS, no duplicados. JS marca
				data-sn-search-open en <html> para presentar como modal. }}
			{{#data-search-box}}
			<div class="sn-searchbox">
				<button type="button" class="sn-search-trigger sn-iconbtn"
					data-sn-search-open aria-expanded="false"
					aria-haspopup="dialog" aria-controls="searchform"
					title="{{msg-searchbutton}}" aria-label="{{msg-searchbutton}}">
					<svg class="sn-i" aria-hidden="true" width="20" height="20" viewBox="0 0 24 24"><use href="#sn-i-search"/></svg>
				</button>
				<form class="sn-search" role="search" action="{{form-action}}" id="searchform"
					aria-label="{{msg-searchbutton}}">
					<button type="button" class="sn-search-close" data-sn-search-close
						aria-label="{{msg-stellanova-close}}" title="{{msg-stellanova-close}}">
						<svg class="sn-i" aria-hidden="true" width="20" height="20" viewBox="0 0 24 24"><use href="#sn-i-x"/></svg>
					</button>
					{{{html-input}}}
					<input type="hidden" name="title" value="{{page-title}}">
					<button type="submit" class="sn-search-go"
						title="{{msg-searchbutton}}" aria-label="{{msg-searchbutton}}">
						<svg class="sn-i" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24"><use href="#sn-i-search"/></svg>
					</button>
				</form>
			</div>
			{{/data-search-box}}

			{{!	Bloque "Página": acciones de edición SUBIDAS a la barra como
				solo-íconos (Editar; Editar con formulario condicional, solo
				si la página tiene formulario asociado vía PageForms) + el
				menú colapsable con el resto (espacios/Discusión, vistas
				restantes, acciones, variantes). El disparador del menú es
				solo ícono + chevron (la palabra "Página" pasa a tooltip). }}
			<div class="sn-pagecluster">
				{{!	UN botón Editar (lápiz), antes del menú. href ya resuelto
					en PHP: formulario si la página tiene uno, clásico si no. }}
				{{#sn-edit}}
				<a class="sn-iconbtn" href="{{href}}" data-sn-quick
					title="{{label}}" aria-label="{{label}}">
					<svg class="sn-i" aria-hidden="true" width="19" height="19" viewBox="0 0 24 24"><use href="#sn-i-edit"/></svg>
				</a>
				{{/sn-edit}}

				<nav class="sn-md sn-pagemenu" aria-label="{{msg-stellanova-pagetools}}">
					<button type="button" class="sn-md-trigger sn-md-icononly"
						aria-expanded="false" aria-haspopup="true" data-sn-menu
						title="{{msg-stellanova-page}}" aria-label="{{msg-stellanova-pagetools}}">
						<svg class="sn-i" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24"><use href="#sn-i-file"/></svg>
						<svg class="sn-i sn-md-caret" aria-hidden="true" width="14" height="14" viewBox="0 0 24 24"><use href="#sn-i-chevron-down"/></svg>
					</button>
					<div class="sn-menu-list">
						<header class="sn-modal-head">
							<h2 class="sn-modal-title">{{msg-stellanova-pagetools}}</h2>
							<button type="button" class="sn-modal-x" data-sn-menu-close
								aria-label="{{msg-stellanova-close}}" title="{{msg-stellanova-close}}">
								<svg class="sn-i" aria-hidden="true" width="20" height="20" viewBox="0 0 24 24"><use href="#sn-i-x"/></svg>
							</button>
						</header>
						<div class="sn-modal-body">
							{{!	"Editar código" (editor clásico) solo cuando la
								página tiene formulario asociado. }}
							{{#sn-editcode}}
							<ul class="sn-mm-grp"><li class="mw-list-item"><a href="{{href}}">
								<svg class="sn-i" aria-hidden="true" width="15" height="15" viewBox="0 0 24 24"><use href="#sn-i-file"/></svg>
								{{label}}
							</a></li></ul>
							{{/sn-editcode}}
							{{#data-portlets}}
							{{#data-namespaces}}<ul class="sn-mm-grp">{{{html-items}}}</ul>{{/data-namespaces}}
							{{/data-portlets}}
							{{#sn-has-pageviews}}<ul class="sn-mm-grp">{{#sn-pageviews}}<li id="{{id}}" class="{{class}}">{{{html}}}</li>{{/sn-pageviews}}</ul>{{/sn-has-pageviews}}
							{{#data-portlets}}
							{{#data-actions}}<ul class="sn-mm-grp">{{{html-items}}}</ul>{{/data-actions}}
							{{#data-variants}}<ul class="sn-mm-grp">{{{html-items}}}</ul>{{/data-variants}}
							{{/data-portlets}}
						</div>
					</div>
				</nav>
			</div>

			{{!	Herramientas del usuario (tri-estado; core decide el set) }}
			<div class="sn-usertools">
				{{#sn-prefs}}{{#is-temporary}}
				<span class="sn-tempbadge" title="{{msg-stellanova-temp-account}}">
					<svg class="sn-i" aria-hidden="true" width="15" height="15" viewBox="0 0 24 24"><use href="#sn-i-clock"/></svg>
				</span>
				{{/is-temporary}}{{/sn-prefs}}

				{{#data-portlets}}
				{{#data-notifications}}
				<nav class="sn-notif" aria-label="{{label}}">{{{html-items}}}</nav>
				{{/data-notifications}}
				{{#data-user-menu}}
				<div class="sn-md sn-usermenu">
					<button type="button" class="sn-usermenu-trigger" aria-expanded="false"
						aria-haspopup="true" data-sn-menu
						aria-label="{{label}}" title="{{label}}">
						<svg class="sn-i" aria-hidden="true" width="20" height="20" viewBox="0 0 24 24"><use href="#sn-i-user"/></svg>
					</button>
					<div class="sn-menu-list">
						<header class="sn-modal-head">
							<h2 class="sn-modal-title">{{label}}</h2>
							<button type="button" class="sn-modal-x" data-sn-menu-close
								aria-label="{{msg-stellanova-close}}" title="{{msg-stellanova-close}}">
								<svg class="sn-i" aria-hidden="true" width="20" height="20" viewBox="0 0 24 24"><use href="#sn-i-x"/></svg>
							</button>
						</header>
						<ul class="sn-modal-body">{{{html-items}}}</ul>
					</div>
				</div>
				{{/data-user-menu}}
				{{/data-portlets}}

				<button type="button" class="sn-prefs-trigger" aria-haspopup="dialog"
					aria-controls="sn-prefs" data-sn-prefs-open
					aria-label="{{msg-stellanova-prefs}}" title="{{msg-stellanova-prefs}}">
					<svg class="sn-i" aria-hidden="true" width="20" height="20" viewBox="0 0 24 24"><use href="#sn-i-sliders"/></svg>
				</button>
			</div>
		</div>
	</header>

	<div class="sn-shell">
		<div class="sn-paper-wrap">
			<article class="sn-paper mw-body">
				<div class="sn-indicators mw-indicators">
					{{#array-indicators}}<div id="{{id}}" class="mw-indicator">{{{html}}}</div>{{/array-indicators}}
				</div>

				{{{html-site-notice}}}
				{{#sn-chrome}}{{#notice}}{{#is-published}}
				<aside class="sn-notice" role="note">{{{html}}}</aside>
				{{/is-published}}{{/notice}}{{/sn-chrome}}

				{{{html-title-heading}}}

				{{!	Sin scaffolding decorativo (ni tagline "De Casiopea" ni caja
					.sn-subhead). Se emiten SOLO las inyecciones de core que el
					contrato de fidelidad exige: html-subtitle (avisos de
					redirección/contexto) y el enlace de restaurar. Vacíos no
					insertan nada visible (:empty → display:none). #contentSub
					se conserva por compatibilidad con gadgets/scripts. }}
				<div id="contentSub" class="sn-subtitle"{{{html-user-language-attributes}}}>{{{html-subtitle}}}</div>
				<div id="contentSub2" class="sn-subtitle">{{{html-undelete-link}}}</div>

				{{{html-user-message}}}

				{{!	NO se renderiza un índice propio: MediaWiki inyecta el TOC
					en SU posición (la que marca __TOC__, o la automática). El
					skin solo lo ESTILIZA in situ (.mw-parser-output .toc),
					respetando la ubicación del magic word. }}

				<div id="sn-content" class="sn-body mw-body-content" tabindex="-1">
					{{{html-body-content}}}
				</div>

				{{{html-categories}}}
			</article>
		</div>
	</div>

	{{!	Pie — replica la LÓGICA del pie de producción (wiki.ead.pucv.cl):
		  1. Bloque institucional gestionado (página Stella-Nova:Pie) — el
		     "espacio" propio del skin, arriba y destacado.
		  2. Última modificación + licencia/atribución (data-info).
		  3. Enlaces de sitio: privacidad · acerca · descargos (data-places).
		  4. "Powered by" MediaWiki / Semantic MediaWiki (data-icons).
		  5. "Herramientas y más" como sección DESPLEGABLE (igual que
		     producción, que la trae colapsable) — el portlet tb.
		Obligaciones core (2-4) SIEMPRE presentes. La navegación del sitio
		(Escuela/Wiki/Navegación) vive en su menú del header, no aquí. }}
	<footer class="sn-footer" role="contentinfo">
		<div class="sn-footer-inner">
			{{!	Col 1 — bloque institucional gestionado (Stella-Nova:Pie). }}
			{{#sn-chrome}}{{#footer}}{{#is-published}}
			<section class="sn-footer-col sn-footer-managed" aria-label="{{msg-sitetitle}}">{{{html}}}</section>
			{{/is-published}}{{/footer}}{{/sn-chrome}}

			{{!	Col 2 — última modificación + licencia (data-info) y los
				enlaces de sitio del namespace Casiopea: privacidad, acerca,
				descargos (data-places). Los logos enlazados (data-icons /
				powered-by) se omiten a propósito. }}
			<div class="sn-footer-col sn-footer-legal" {{{html-user-language-attributes}}}>
				{{#data-footer}}
				{{#data-info}}<ul class="sn-foot-info" id="{{id}}">{{#array-items}}<li id="{{id}}">{{{html}}}</li>{{/array-items}}</ul>{{/data-info}}
				{{#data-places}}<ul class="sn-foot-places" id="{{id}}">{{#array-items}}<li id="{{id}}">{{{html}}}</li>{{/array-items}}</ul>{{/data-places}}
				{{/data-footer}}
			</div>

			{{!	Col 3 — "Herramientas y más" (portlet tb) con ícono. }}
			{{#sn-toolbox}}{{^is-empty}}
			<nav class="sn-footer-col sn-footer-tools" aria-label="{{label}}">
				<h2 class="sn-footer-h">
					<svg class="sn-i" aria-hidden="true" width="15" height="15" viewBox="0 0 24 24"><use href="#sn-i-tool"/></svg>
					{{#label}}{{.}}{{/label}}{{^label}}{{msg-stellanova-managed-nav}}{{/label}}
				</h2>
				<ul class="sn-footer-toollist">{{{html-items}}}</ul>
			</nav>
			{{/is-empty}}{{/sn-toolbox}}
		</div>
	</footer>
</div>

{{/is-sn-fullscreen}}

{{!	PreferencesPanel — diálogo. Expone las 5 preferencias resueltas + las
	señales del SO. provides SavePreferences / ResetPreferences. JS lo hace
	modal accesible; sin JS sigue siendo un formulario legible.
	Se emite FUERA de los condicionales para que también esté disponible
	desde el modal único de pantalla completa (data-sn-prefs-open en la
	sección "Preferencias"). }}
<div class="sn-prefs-scrim" data-sn-prefs-scrim hidden></div>
<aside class="sn-prefs" id="sn-prefs" role="dialog" aria-modal="true"
	aria-labelledby="sn-prefs-title" hidden>
	<form class="sn-prefs-form" data-sn-prefs-form>
		<header class="sn-prefs-head">
			<h2 id="sn-prefs-title">{{msg-stellanova-prefs}}</h2>
			<button type="button" class="sn-prefs-x" data-sn-prefs-close
				aria-label="{{msg-stellanova-close}}" title="{{msg-stellanova-close}}">
				<svg class="sn-i" aria-hidden="true" width="20" height="20" viewBox="0 0 24 24"><use href="#sn-i-x"/></svg>
			</button>
		</header>
		<div class="sn-prefs-body">
			<fieldset class="sn-pref">
				<legend>{{msg-stellanova-pref-theme}}</legend>
				<div class="sn-seg" role="radiogroup" data-sn-pref="theme" data-sn-os="{{sn-prefs.os-scheme}}">
					<button type="button" data-v="auto">{{msg-stellanova-auto}}</button>
					<button type="button" data-v="light">{{msg-stellanova-theme-light}}</button>
					<button type="button" data-v="dark">{{msg-stellanova-theme-dark}}</button>
				</div>
			</fieldset>
			<fieldset class="sn-pref">
				<legend>{{msg-stellanova-pref-font}}</legend>
				<div class="sn-seg" role="radiogroup" data-sn-pref="font">
					<button type="button" data-v="small">{{msg-stellanova-sz-s}}</button>
					<button type="button" data-v="medium">{{msg-stellanova-sz-m}}</button>
					<button type="button" data-v="large">{{msg-stellanova-sz-l}}</button>
				</div>
			</fieldset>
			<fieldset class="sn-pref">
				<legend>{{msg-stellanova-pref-toc}}</legend>
				<div class="sn-seg" role="radiogroup" data-sn-pref="toc">
					<button type="button" data-v="persistent">{{msg-stellanova-toc-persistent}}</button>
					<button type="button" data-v="inline">{{msg-stellanova-toc-inline}}</button>
				</div>
			</fieldset>
			<label class="sn-pref sn-pref-row">
				<span>{{msg-stellanova-pref-collapsible}}</span>
				<input type="checkbox" class="sn-switch" data-sn-pref="collapsible">
			</label>
			<label class="sn-pref sn-pref-row">
				<span>{{msg-stellanova-pref-motion}}<small>{{msg-stellanova-pref-motion-hint}}</small></span>
				<input type="checkbox" class="sn-switch" data-sn-pref="motion">
			</label>
		</div>
		<footer class="sn-prefs-foot">
			<p class="sn-prefs-scope" data-sn-scope>
				{{#sn-prefs}}
				{{#is-registered}}{{msg-stellanova-prefs-scope-account}}{{/is-registered}}
				{{^is-registered}}{{msg-stellanova-prefs-scope-browser}}{{/is-registered}}
				{{/sn-prefs}}
			</p>
			<button type="button" class="sn-btn sn-btn-ghost" data-sn-prefs-reset disabled>{{msg-stellanova-reset}}</button>
		</footer>
	</form>
</aside>

{{{html-after-content}}}
{{{html-printtail}}}
{{>SnIcons}}
</body>
</html>
