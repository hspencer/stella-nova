{
	"manifest_version": 2,
	"name": "StellaNova",
	"namemsg": "skinname-stellanova",
	"version": "0.6.14",
	"author": [
		"[https://herbertspencer.net Herbert Spencer González], e[ad] Escuela de Arquitectura y Diseño, Pontificia Universidad Católica de Valparaíso"
	],
	"url": "https://github.com/hspencer/stella-nova",
	"descriptionmsg": "stellanova-desc",
	"license-name": "GPL-2.0-or-later",
	"type": "skin",
	"requires": {
		"MediaWiki": ">= 1.43.0"
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Skins\\StellaNova\\": "includes/"
	},
	"ValidSkinNames": {
		"stellanova": {
			"class": "MediaWiki\\Skins\\StellaNova\\SkinStellaNova",
			"args": [
				{
					"name": "stellanova",
					"responsive": true,
					"templateDirectory": "includes/templates",
					"styles": [],
					"scripts": [
						"skins.stellanova.scripts"
					],
					"messages": [
						"sitetitle",
						"searchbutton",
						"tagline",
						"toc",
						"stellanova-skip-to-content",
						"stellanova-skip-to-nav",
						"stellanova-sidebar",
						"stellanova-home",
						"stellanova-escape",
						"stellanova-menu",
						"stellanova-mainpage",
						"stellanova-search",
						"stellanova-thispage",
						"stellanova-user",
						"stellanova-temp-account",
						"stellanova-managed-nav",
						"stellanova-pagetools",
						"stellanova-nav",
						"stellanova-page",
						"stellanova-close",
						"stellanova-auto",
						"stellanova-pref-theme",
						"stellanova-theme-light",
						"stellanova-theme-dark",
						"stellanova-pref-font",
						"stellanova-sz-s",
						"stellanova-sz-m",
						"stellanova-sz-l",
						"stellanova-pref-family",
						"stellanova-family-sans",
						"stellanova-family-serif",
						"stellanova-tools"
					],
					"menus": [
						"user-menu",
						"user-interface-preferences",
						"notifications",
						"views",
						"actions",
						"namespaces",
						"associated-pages",
						"variants"
					]
				}
			]
		}
	},
	"MessagesDirs": {
		"StellaNova": [
			"i18n"
		]
	},
	"ExtensionMessagesFiles": {
		"StellaNovaMagic": "StellaNova.i18n.magic.php"
	},
	"Hooks": {
		"GetDoubleUnderscoreIDs": "MediaWiki\\Skins\\StellaNova\\Hooks::onGetDoubleUnderscoreIDs",
		"OutputPageParserOutput": "MediaWiki\\Skins\\StellaNova\\Hooks::onOutputPageParserOutput",
		"GetPreferences": "MediaWiki\\Skins\\StellaNova\\Hooks::onGetPreferences",
		"UserGetDefaultOptions": "MediaWiki\\Skins\\StellaNova\\Hooks::onUserGetDefaultOptions",
		"BeforePageDisplay": "MediaWiki\\Skins\\StellaNova\\Hooks::onBeforePageDisplay",
		"ResourceLoaderRegisterModules": "MediaWiki\\Skins\\StellaNova\\Hooks::onResourceLoaderRegisterModules"
	},
	"_comment_ResourceModules": "skins.stellanova.styles y .scripts se registran en PHP (Hooks::onResourceLoaderRegisterModules) con remoteSkinPath calculado de la carpeta REAL del skin (robusto al nombre del directorio al clonar). Ademas, `styles` esta vacio a proposito: la CSS critica del skin NO la carga MediaWiki en su <link> combinado (que va SIN version y se cachea rancio tras cada deploy), sino Hooks::onBeforePageDisplay con un <link> propio cuyo `version` es el hash de contenido de RL → caché larga inmutable + bust automático en cada cambio de CSS, sin acceso al servidor.",
	"ResourceModuleSkinStyles": {
		"stellanova": {
			"localBasePath": "resources",
			"remoteSkinPath": "StellaNova/resources",
			"+ext.3DAlloy": "skinStyles/3dalloy.css",
			"+ext.MsUpload": "skinStyles/msupload.less",
			"+ext.ReplaceTextStyles": "skinStyles/replacetext.less",
			"+ext.SimpleBatchUpload": "skinStyles/simplebatchupload.css",
			"+ext.SimpleBatchUpload.jquery-file-upload": "skinStyles/simplebatchupload.css",
			"+ext.categoryTree.styles": "skinStyles/categorytree.less",
			"+ext.cite.styles": "skinStyles/cite.less",
			"+ext.cite.ux-enhancements": "skinStyles/cite.less",
			"+ext.codeEditor.styles": "skinStyles/codeeditor.css",
			"+ext.confirmEdit.editPreview.ipwhitelist.styles": "skinStyles/confirmedit.css",
			"+ext.confirmEdit.simpleCaptcha": "skinStyles/confirmedit.css",
			"+ext.echo.special": "skinStyles/echo.base.less",
			"+ext.echo.styles.alert": "skinStyles/echo.base.less",
			"+ext.echo.styles.badge": "skinStyles/echo.base.less",
			"+ext.echo.styles.notifications": "skinStyles/echo.base.less",
			"+ext.echo.styles.special": "skinStyles/echo.base.less",
			"+ext.imagemap.styles": "skinStyles/imagemap.css",
			"+jquery.ui": "skinStyles/jquery.ui.css",
			"+ext.inlineComments.diff.styles": "skinStyles/inlinecomments.css",
			"+ext.inlineComments.makeComment": "skinStyles/inlinecomments.css",
			"+ext.inlineComments.sidenotes.styles": "skinStyles/inlinecomments.css",
			"+ext.maps.leaflet.fullscreen": "skinStyles/maps.base.css",
			"+ext.maps.leaflet.library": "skinStyles/maps.base.css",
			"+ext.maps.leaflet.markercluster": "skinStyles/maps.base.css",
			"+ext.math.styles": "skinStyles/math.css",
			"+ext.mermaid": "skinStyles/mermaid.css",
			"+ext.nuke.styles": "skinStyles/nuke.css",
			"+ext.pageNotice": "skinStyles/pagenotice.css",
			"+ext.pageforms.checkboxes.styles": "skinStyles/pageforms.css",
			"+ext.pageforms.forminput.styles": "skinStyles/pageforms.css",
			"+ext.pageforms.main.styles": "skinStyles/pageforms.css",
			"+ext.pageforms.rating.styles": "skinStyles/pageforms.css",
			"+ext.pageforms.submit.styles": "skinStyles/pageforms.css",
			"+ext.smw.ask.styles": "skinStyles/smw.css",
			"+ext.smw.browse.styles": "skinStyles/smw.css",
			"+ext.smw.deferred.styles": "skinStyles/smw.css",
			"+ext.smw.factbox.styles": "skinStyles/smw.css",
			"+ext.smw.page.styles": "skinStyles/smw.css",
			"+ext.smw.special.styles": "skinStyles/smw.css",
			"+ext.smw.styles": "skinStyles/smw.css",
			"+ext.smw.table.styles": "skinStyles/smw.css",
			"+ext.smw.tooltip.styles": "skinStyles/smw.css",
			"+smw.special.facetedsearch.styles": "skinStyles/smw.css",
			"+ext.srf": "skinStyles/srf.css",
			"+ext.srf.datatables.v": "skinStyles/srf.css",
			"+ext.templateData": "skinStyles/templatedata.css",
			"+ext.timeline.styles": "skinStyles/easytimeline.css",
			"+ext.wikiEditor.styles": "skinStyles/wikieditor.css",
			"+mediawiki.action.edit.styles": "skinStyles/edit.css",
			"+mediawiki.htmlform.styles": "skinStyles/htmlform.css",
			"+mediawiki.notification": "skinStyles/notification.css",
			"+mediawiki.pager.styles": "skinStyles/pager.css",
			"+mediawiki.rcfilters.filters.ui": "skinStyles/rcfilters.css",
			"+mediawiki.special.preferences.styles.ooui": "skinStyles/preferences.css",
			"+oojs-ui-core.styles": "skinStyles/oojs-ui.css",
			"+oojs-ui-widgets.styles": "skinStyles/oojs-ui.css",
			"+oojs-ui-windows.styles": "skinStyles/oojs-ui.css"
		}
	}
}
