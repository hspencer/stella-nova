-- allium: 3
--
-- Stella Nova — especificación de comportamiento del skin.
--
-- ALCANCE. Allium describe comportamiento observable, no presentación.
-- Por eso este spec NO modela (y deliberadamente lo deja a ARCHITECTURE.md /
-- tokens.css / CSS):
--   · tipografía (IBM Plex Sans + IBM Plex Serif + IBM Plex Mono): cargar vs.
--     clonar es decisión de empaquetado,
--   · feather icons, la metáfora "página de papel", fondo gris ahuesado,
--   · tokens semánticos en archivos separados, layout/posiciones exactas,
--   · la PRESENTACIÓN de la navegación: que el chrome del sitio se muestre
--     como riel lateral, como dropdowns en barra superior o colapsado tras
--     hamburguesa es decisión de presentación (hoy: dropdowns superiores +
--     hamburguesa en pantallas pequeñas, sin riel persistente — decisión
--     de producto 2026-05-18). El spec sólo fija QUÉ regiones existen y
--     qué exponen, no DÓNDE se sitúan ni su afordancia de despliegue,
--   · justificación + hyphenation de párrafos del cuerpo (decisión de
--     presentación editorial 2026-05-26),
--   · la búsqueda y el logo→home (comportamiento de MediaWiki core, no del skin).
--
-- Sí modela los núcleos con estado y decisión condicional:
--   1. Preferencias de skin (5, ver enum lista abajo): resolución por
--      campo explícito > SO (donde aplica) > default. EXCEPCIÓN tema:
--      default claro; el SO sólo aplica si la elección es `auto`
--      (decisión de producto 2026-05-18). Persistencia híbrida por
--      identidad — registrado → cuenta MediaWiki (BBDD, cross-device);
--      anónimo/temporal → sesión del navegador (por-navegador).
--      NOTA 2026-05-26: el conjunto se redujo de 7 a 5 — se retiraron
--      ContentWidth y LineHeight porque la métrica de la hoja y la
--      interlínea del cuerpo participan del cálculo del baseline grid
--      (--sn-baseline = fs-base × leading); dejarlas modulables al
--      usuario desparametrizaba el ajuste vertical entre cabeceras y
--      párrafos. Ambos quedaron como tokens fijos en tokens.css.
--   2. Chrome administrable desde páginas wiki del namespace Stella-Nova
--      (pie, barra lateral, aviso): visibilidad y autorización CRUD.
--   3. Qué expone cada región según identidad (anónimo / cuenta temporal
--      1.43 / registrado).
--   4. Modo de página: standard (chrome del tema) | fullscreen (control
--      total para páginas experimentales; sólo afordancia de escape).
--   5. Pie compuesto: obligaciones core de MediaWiki (última modificación,
--      licencia/atribución, places, icons, hooks) SIEMPRE + un bloque
--      institucional gestionado desde una página del namespace del skin.
--   6. Contrato de fidelidad estructural: el skin emite todas las data
--      keys de SkinMustache y respeta los puntos de inyección de las
--      extensiones de Casiopea (SMW/SRF/PageForms/Widgets/…).
--   7. Contrato de accesibilidad del chrome: todo control interactivo
--      expone un nombre accesible discoverable; cada surface de chrome
--      es alcanzable y operable en cualquier viewport (la realización
--      puede compactar la presentación pero no suprimir surfaces por
--      estrechez). Decisión de producto 2026-05-24 a raíz de la pasada
--      de responsiveness mobile.
--   8. Contrato de panel emergente: cuando una surface se presenta como
--      overlay temporal (preferencias siempre; navegación, herramientas
--      de página, menú de usuario o búsqueda cuando la realización los
--      colapsa así), el panel es descartable por Escape y por activación
--      fuera, atrapa el foco mientras esté abierto y contiene su propio
--      scroll para contenido desbordante.

------------------------------------------------------------
-- External Entities
------------------------------------------------------------

-- Gobernadas por MediaWiki, no por este spec.

external entity User {
    identity: UserIdentity          -- anónimo-IP / cuenta temporal / registrado
    groups: Set<String>             -- nombres de grupos MediaWiki
}

external entity WikiPage {
    namespace: String
    exists: Boolean
    content: String?                -- wikitexto; null si la página no existe
}

-- Cualquier operación mutante (crear, editar, mover, borrar) sobre una
-- página: la "C/U/D" del CRUD. La "R" (ver el fragmento renderizado) es
-- pública y se modela en la surface ManagedChrome, no aquí.
external entity ChromePageWrite {
    actor: User
    page: WikiPage
    outcome: pending | permitted | denied
}

-- Marcador de tipo: el documento HTML que MediaWiki/SkinMustache produce.
-- Su forma la gobierna MediaWiki; aquí sólo es la frontera del contrato
-- de fidelidad estructural.
external entity RenderedDocument {}

------------------------------------------------------------
-- Contracts
------------------------------------------------------------

-- Obligación de fidelidad: Stella Nova se escribe desde cero, pero NO
-- puede recortar lo que MediaWiki y las extensiones de Casiopea emiten.
-- Esta es la protección más fuerte para la carga SMW/PageForms/Widgets
-- (doctrina en ARCHITECTURE.md §3). Verificación: snapshot del DOM contra
-- vector-2022 en las páginas reales de Fase 5.
contract SkinRenderFidelity {
    render: (page: WikiPage, viewer: User) -> RenderedDocument

    @invariant StandardKeysEmitted
        -- El documento emite TODAS las data keys estándar de SkinMustache
        -- 1.43, aunque el skin no las estilice: html-headelement,
        -- html-title-heading, html-subtitle, html-body-content,
        -- html-categories (catlinks), html-site-notice, html-undelete-link,
        -- html-after-content, html-printtail; data-portlets (sidebar y los
        -- nombrados: user-menu, notifications, user-interface-preferences,
        -- views, actions, namespaces, associated-pages, variants);
        -- data-search-box; data-footer (data-info = última modificación +
        -- licencia/atribución, data-places = privacidad/acerca/aviso,
        -- data-icons); data-toc; data-indicators; link-mainpage; data-logos.

    @invariant CoreFooterAlwaysPresent
        -- Las obligaciones de data-footer (última modificación, licencia/
        -- atribución, places, icons y hooks de extensión) se renderizan
        -- SIEMPRE, con independencia del bloque institucional gestionado
        -- (ver surface ManagedChrome). Suprimirlas rompería la atribución
        -- de la licencia de contenido.

    @invariant NoExtensionHtmlStripped
        -- El HTML inyectado por extensiones nunca se elimina ni se
        -- reestructura su DOM; el skin sólo lo envuelve y estiliza.

    @invariant FactboxPlacement
        -- El Factbox de SemanticMediaWiki se renderiza en su posición
        -- (junto al cuerpo), dentro de mw-body-content; no se reubica.

    @invariant SemanticResultsPlacement
        -- Resultados de #ask / SemanticResultFormats (tablas, listas,
        -- mapas, etc.) conservan su markup; el desbordamiento se resuelve
        -- por contenedor (overflow), nunca recortando contenido.

    @invariant PageFormsPlacement
        -- Formularios PageForms viven dentro de html-body-content; el
        -- skin no recorta su markup ni los estilos TemplateStyles.

    @invariant WidgetsOutputPreserved
        -- La salida de Widgets/Smarty (incl. el lienzo experimental y
        -- p5.js) se emite intacta; el skin no la sanitiza ni la envuelve
        -- de forma que rompa su CSS/JS.

    @invariant InjectionHooksEmitted
        -- Los puntos de inyección de extensiones se emiten intactos:
        -- html-after-content (DiscussionTools, RelatedArticles, SMW),
        -- data-indicators (estados de página), catlinks (categorías,
        -- incl. ocultas según preferencia), html-subtitle (redirecciones,
        -- contexto de discusión).

    @invariant SpecialPageOutput
        -- Páginas Special: sin pestañas de artículo se renderizan sin
        -- inventar acciones inexistentes; el cuerpo de OutputPage íntegro.

    @guidance
        -- Lista viva: al añadir/quitar extensiones en Casiopea se ajusta
        -- la enumeración. Ámbito de extensiones actual confirmado en
        -- ARCHITECTURE.md §3 y CLAUDE.md (Fase 4): SMW, SCQ, SRF,
        -- PageForms, ParserFunctions, WikiEditor, TemplateStyles, Maps,
        -- Widgets, Mermaid, Cite, Poem, Math, ImageMap, CategoryTree.
}

-- Obligaciones de accesibilidad del chrome. Direccionalidad: el skin las
-- CUMPLE. No condicionan en viewport: el skin puede compactar la
-- presentación en pantallas estrechas, pero la operabilidad y el etiquetado
-- son universales. Decisión de producto 2026-05-24 (pasada mobile).
contract ChromeAccessibility {
    render_chrome: (page: WikiPage, viewer: User) -> RenderedDocument

    @invariant InteractiveChromeControlsLabelled
        -- Cada elemento interactivo del chrome (botón, enlace, control de
        -- formulario, disparador de menú) expone un nombre accesible
        -- discoverable por hover (atributo title o tooltip equivalente)
        -- Y por tecnologías asistivas (aria-label, aria-labelledby o
        -- texto perceptible del propio elemento). Aplica al chrome
        -- COMPLETO (barra superior, pie, paneles, indicadores), no sólo
        -- a la barra. Los controles con texto visible legible pueden
        -- valerse de su propio texto como nombre accesible; los
        -- ÍCONO-ONLY DEBEN proveer label explícito.

    @invariant ChromeReachableInAnyViewport
        -- Cada surface de chrome (PreferencesPanel, UserTools,
        -- ManagedChrome en sus tres slots, SiteIsotype, la búsqueda y
        -- la navegación expuestas vía portlets y vía ManagedChrome.sidebar)
        -- es alcanzable y operable en CUALQUIER viewport, incluyendo
        -- los más estrechos. La realización puede COMPACTAR la
        -- presentación (colapso a icon-only, paso a overlay, recombinación
        -- de afordancias), pero NO puede suprimir la surface ni recortar
        -- sus operaciones por estrechez de viewport. La única supresión
        -- legítima del chrome es LayoutMode.fullscreen (ver
        -- SuppressedInFullscreen en cada surface afectada).

    @guidance
        -- "Compactar" incluye, p. ej., reemplazar el input de búsqueda
        -- por una afordancia que lo expone bajo demanda, o sustituir un
        -- menú inline por un panel emergente. Todas estas son decisiones
        -- de presentación; el contrato sólo prohíbe que se pierda
        -- alcance u operabilidad.
}

-- Obligaciones de comportamiento de un panel emergente. Se invoca cuando
-- una surface del chrome se presenta como overlay temporal (modal, dropdown
-- con scrim, drawer dismissable). PreferencesPanel lo cumple siempre; el
-- resto (UserTools, presentación de ManagedChrome.sidebar, portlets de
-- página, búsqueda) cuando la realización los colapsa así — típicamente
-- en viewports estrechos. Decisión de producto 2026-05-24.
contract TransientPanel {
    present: (viewer: User) -> RenderedDocument

    @invariant DismissableByEscape
        -- La tecla Escape cierra el panel emergente más reciente sin
        -- confirmación intermedia. No usar este contrato en paneles que
        -- recogen datos no guardables que el descarte por Escape pueda
        -- perder.

    @invariant DismissableByOutsideActivation
        -- Una activación (click o tap) fuera del cuerpo del panel lo
        -- cierra. Compatible con el patrón "scrim" típico de mobile.

    @invariant FocusContained
        -- Mientras el panel está abierto, la navegación por teclado
        -- (Tab/Shift-Tab) se mantiene dentro del panel: el foco no
        -- escapa al body subyacente. Implementa el patrón ARIA dialog.

    @invariant SelfContainedScroll
        -- Cuando el contenido del panel excede el alto disponible, el
        -- propio panel scrollea internamente. El scroll del panel NO
        -- requiere ni dispara scroll de la página subyacente. Garantiza
        -- que ningún ítem del panel quede inalcanzable en pantallas
        -- pequeñas.
}

------------------------------------------------------------
-- Enumerations
------------------------------------------------------------

-- Tema APLICADO: siempre resuelto a claro u oscuro (ver
-- ViewingSession.active_theme e invariante ThemeAlwaysResolved).
enum Theme { light | dark }

-- Elección de tema del usuario (lo que guarda): tres valores. `auto`
-- significa "seguir al SO"; light|dark fuerzan. Distinta del tema
-- aplicado (Theme): sin elección guardada el default es CLARO y el SO
-- NO oscurece por sí solo — sólo se sigue al SO si se eligió `auto`.
enum ThemeChoice { light | dark | auto }

-- MediaWiki 1.43: el editor no autenticado obtiene una cuenta temporal
-- (IP-masking, nombre ~AAAA-NNN, no puede loguear, features limitadas);
-- distinta del anónimo-IP clásico y del registrado.
enum UserIdentity { anonymous | temporary | registered }

-- Identidades de región del chrome gestionado (cada una = una página
-- wiki del namespace del skin), NO posiciones en pantalla. `sidebar` es
-- el fragmento institucional de navegación; su presentación (riel,
-- dropdown, hamburguesa) la fija la realización, no el spec.
enum ChromeSlot { footer | sidebar | notice }

enum LayoutMode { standard | fullscreen }

-- Las 5 preferencias de skin (estilo Citizen/Vector-2022). Histórico
-- 2026-05-26: se retiraron ContentWidth y LineHeight (ver nota de
-- ALCANCE arriba); ambas son fijas a nivel de token y no exhibidas al
-- usuario.
enum FontSize { small | medium | large }
enum Toggle { enabled | disabled }
enum TocMode { persistent | inline }
enum Motion { full | reduced }

------------------------------------------------------------
-- Value Types
------------------------------------------------------------

-- El conjunto de 5 preferencias de skin. Cada campo es opcional: null =
-- "sin elección explícita" → se resuelve por default (y, donde aplica,
-- por SO). El tema es el caso especial: null → claro (el SO NO aplica);
-- el SO sólo influye si theme = auto. Los demás (p. ej. motion) sí
-- toman la señal del SO en ausencia de elección.
value Preferences {
    theme: ThemeChoice?
    font_size: FontSize?
    collapsible_sections: Toggle?       -- recordar estado de secciones
    toc_mode: TocMode?                  -- índice persistente vs en línea
    reduced_motion: Motion?             -- override de prefers-reduced-motion
}

------------------------------------------------------------
-- Entities
------------------------------------------------------------

-- Una sesión de visualización. `saved` es el conjunto explícito que el
-- usuario guardó; DÓNDE vive es realización (registrado → cuenta MW/BBDD,
-- cross-device; anónimo/temporal → sesión del navegador) — ver
-- ViewerUpdatesPreferences. `os_scheme`/`os_motion` son señales del SO.
entity ViewingSession {
    user: User
    os_scheme: Theme?               -- prefers-color-scheme; null = sin señal
    os_motion: Motion?              -- prefers-reduced-motion; null = sin señal
    saved: Preferences?             -- null = nada explícito guardado aún

    -- Resolución por campo: explícito > SO (donde aplica) > default skin.
    -- Defaults de diseño (tunables por globales del skin en realización,
    -- ARCHITECTURE.md §6). active_theme nunca indeterminado.
    --
    -- TEMA (decisión de producto 2026-05-18): el default es CLARO y el SO
    -- NO oscurece por sí solo. saved.theme = auto → seguir al SO (claro si
    -- no hay señal); = light|dark → forzado; sin elección (null) → claro.
    -- Sólo `auto` deja entrar prefers-color-scheme. El resto de campos sí
    -- siguen "explícito > SO > default" (p. ej. motion).
    active_theme:
        if saved?.theme = auto: os_scheme ?? light
        else if saved?.theme = dark: dark
        else if saved?.theme = light: light
        else: light
    active_motion: saved?.reduced_motion ?? os_motion ?? full
    active_font_size: saved?.font_size ?? medium
    active_collapsible: saved?.collapsible_sections ?? enabled
    active_toc_mode: saved?.toc_mode ?? persistent
}

-- Conjunto cerrado de tres regiones (footer, sidebar, notice). No es un
-- modelo genérico: añadir una cuarta exige editar ChromeSlot (cambio de spec),
-- que es exactamente la decisión "tres instancias concretas" tomada.
entity InterfaceFragment {
    slot: ChromeSlot
    -- Resolución de la fuente: por preferencia, la página de nombre del
    -- slot en el namespace de chrome (config.chrome_namespace). Si ese
    -- namespace NO está realizado en la instalación, la fuente es la
    -- página homónima del espacio principal cuyo título es, literalmente,
    -- "<chrome_namespace>:<slot>". La publicación (is_published) es
    -- idéntica en ambos casos; lo que cambia es la autorización de
    -- escritura — ver source_protected y RestrictChromeNamespaceWrites.
    source_page: WikiPage

    -- Verdadero sólo si la fuente vive en el namespace dedicado; entonces
    -- (y sólo entonces) RestrictChromeNamespaceWrites restringe la
    -- escritura. En modo fallback (main ns) es falso: sin protección.
    source_protected: source_page.namespace = config.chrome_namespace

    -- "is_blank" es una función caja-negra: contenido vacío tras recortar
    -- espacios/comentarios (semántica exacta = pregunta abierta).
    is_published: source_page.exists
        and source_page.content != null
        and not is_blank(source_page.content)
}

-- Cómo se renderiza una página concreta. `mode` lo declara la propia
-- página con el magic word __PANTALLACOMPLETA__ en su wikitexto; standard
-- en su defecto (realización: behaviour switch detectado al parsear, sin
-- propiedad SMW). Cualquier editor puede declararlo: quitar el chrome es
-- bajo riesgo; el riesgo de script vive en el mecanismo de inyección JS
-- (hoy Common.js global), no en el wikitexto de la página.
entity PageRender {
    page: WikiPage
    mode: LayoutMode
}

------------------------------------------------------------
-- Config
------------------------------------------------------------

config {
    skin_version: String = "0.0.7"      -- debe coincidir con skin.json
    chrome_namespace: String = "Stella-Nova"
    interface_editor_group: String = "editores-de-interfaz"
}

------------------------------------------------------------
-- Rules
------------------------------------------------------------

-- El visitante guarda su conjunto de preferencias desde el panel.
rule ViewerUpdatesPreferences {
    when: SavePreferences(session, prefs)
    ensures: session.saved = prefs
    @guidance
        -- Persistencia por identidad (session.user.identity):
        --   registered → preferencia de cuenta MediaWiki (BBDD); sigue al
        --     usuario entre navegadores y dispositivos (cross-device).
        --   anonymous | temporary → sesión del navegador
        --     (cookie/localStorage); por-navegador, no migra. La cuenta
        --     temporal 1.43 no se loguea, por lo que nunca es cross-device.
}

-- El visitante restablece: vuelve a SO/defaults del skin.
rule ViewerResetsPreferences {
    when: ResetPreferences(session)
    requires: session.saved != null
    ensures: session.saved = null
}

-- Toda escritura sobre el namespace de chrome (crear/editar/mover/borrar)
-- queda restringida al grupo dedicado o a sysop: CRUD completo para ellos.
-- El skin define namespace y grupo; el WIKI aplica el derecho.
rule RestrictChromeNamespaceWrites {
    when: op: ChromePageWrite.created
    requires: op.page.namespace = config.chrome_namespace
    ensures:
        if config.interface_editor_group in op.actor.groups
            or "sysop" in op.actor.groups:
            op.outcome = permitted
        else:
            op.outcome = denied
    @guidance
        -- Realizado vía $wgNamespaceProtection / derechos de grupo en
        -- LocalSettings, con Especial:PermisosUsuario para asignar el grupo
        -- (administrable por admins). No re-especifica la gestión de grupos
        -- de MediaWiki. La lectura del fragmento renderizado es pública.
        -- Las cuentas temporales (1.43) carecen del grupo y de sysop →
        -- denegadas, comportamiento correcto.
        --
        -- CONSECUENCIA del fallback (ver InterfaceFragment.source_page /
        -- ManagedChrome.SourceResolution): el `requires` sólo casa cuando
        -- la página está en config.chrome_namespace. Si el namespace NO
        -- está realizado y la fuente es la página homónima del espacio
        -- principal, esta regla NO casa → esas escrituras quedan SIN
        -- restringir (cualquiera con permiso de edición puede tocarlas).
        -- La garantía de autorización sólo se sostiene declarando el
        -- namespace dedicado; el fallback es conveniencia, no seguridad.
}

------------------------------------------------------------
-- Invariants
------------------------------------------------------------

-- El tema aplicado siempre se resuelve a claro u oscuro: nunca indeterminado
-- (el fallback final a `light` lo garantiza).
invariant ThemeAlwaysResolved {
    for s in ViewingSessions:
        s.active_theme = light or s.active_theme = dark
}

------------------------------------------------------------
-- Surfaces
------------------------------------------------------------

-- Panel de preferencias. Público: cualquier visitante (anónimo, temporal
-- o registrado). Las 5 preferencias estilo Citizen.
surface PreferencesPanel {
    facing viewer: User
    context session: ViewingSession where user = viewer

    exposes:
        session.active_theme
        session.active_motion
        session.active_font_size
        session.active_collapsible
        session.active_toc_mode
        session.os_scheme
        session.os_motion

    provides:
        SavePreferences(session, prefs)
        ResetPreferences(session)
            when session.saved != null

    @guarantee Precedence
        -- Cada preferencia se resuelve: valor explícito guardado >
        -- señal del SO (donde aplica) > default de diseño del skin.
        -- El SO aplica al motion (← prefers-reduced-motion) sin elección.
        -- EXCEPCIÓN tema (decisión de producto): el default es claro y el
        -- SO (prefers-color-scheme) sólo influye si la elección guardada
        -- es `auto`; sin elección → claro, no el esquema del SO.
        -- active_theme nunca es indeterminado (siempre claro u oscuro).

    @guarantee CrossDeviceForRegistered
        -- identity = registered: lo guardado persiste en la cuenta
        -- MediaWiki y sigue al usuario entre navegadores y dispositivos.

    @guarantee PerBrowserOtherwise
        -- identity = anonymous | temporary: lo guardado vive en la sesión
        -- del navegador; por-navegador, no migra entre dispositivos.

    @guarantee SuppressedInFullscreen
        -- No se renderiza cuando la página vista está en
        -- LayoutMode.fullscreen (ver surface ExperimentalCanvas).

    contracts:
        fulfils TransientPanel
}

-- Regiones de chrome administradas desde páginas wiki. Una instancia de
-- surface por fragmento (footer, sidebar, notice).
--
-- IMPORTANTE para el slot `footer`: el pie es COMPUESTO. Este fragmento
-- gestionado es SÓLO el bloque institucional. Las obligaciones core del
-- pie (última modificación, licencia/atribución, places, icons, hooks de
-- extensión) las garantiza SkinRenderFidelity.CoreFooterAlwaysPresent con
-- independencia de este bloque: ocultar el fragmento NO oculta el pie core.
surface ManagedChrome {
    facing viewer: User
    context fragment: InterfaceFragment

    exposes:
        fragment.slot
        fragment.source_page.content
            when fragment.is_published

    @guarantee SourceResolution
        -- La fuente del fragmento se resuelve, por preferencia, a la
        -- página del slot en el namespace dedicado (config.chrome_namespace);
        -- si ese namespace NO está realizado en la instalación, a la
        -- página homónima del espacio principal ("<chrome_namespace>:
        -- <slot>"). La publicación y su lectura son IDÉNTICAS en ambos
        -- casos. La diferencia es de autorización: sólo con la fuente en
        -- el namespace dedicado (fragment.source_protected) la escritura
        -- queda restringida (RestrictChromeNamespaceWrites). El modo
        -- fallback es de conveniencia y SIN protección: declarar el
        -- namespace es lo recomendado para producción.

    @guarantee HiddenWhenUnpublished
        -- "Sin fallback" aquí significa: si is_published es falso (página
        -- ausente o en blanco) SÓLO este bloque gestionado se omite, sin
        -- contenido por defecto/placeholder para él (distinto de la
        -- resolución de fuente de SourceResolution, que es sobre QUÉ
        -- página, no sobre contenido por defecto). El pie core de
        -- MediaWiki es independiente y sigue presente (ver
        -- SkinRenderFidelity.CoreFooterAlwaysPresent).

    @guarantee SuppressedInFullscreen
        -- No se renderiza cuando la página vista está en
        -- LayoutMode.fullscreen (ver surface ExperimentalCanvas).
}

-- Herramientas de usuario en el horizonte superior. Lo que se ofrece
-- depende de la autenticación; el skin renderiza el conjunto correcto,
-- no inventa el comportamiento de sesión (lo posee MediaWiki).
surface UserTools {
    facing viewer: User
    context session: ViewingSession where user = viewer

    exposes:
        session.user.identity

    @guarantee AuthDependentTools
        -- identity = anonymous → expone sólo iniciar sesión / crear cuenta.
        -- identity = temporary → expone el nombre temporal, un aviso de
        --   "cuenta temporal" y la invitación a crear cuenta / iniciar
        --   sesión (no hay logout: la cuenta temporal no se loguea).
        -- identity = registered → expone el menú de usuario (discusión,
        --   preferencias, seguimiento, contribuciones) y cerrar sesión.

    @guarantee SuppressedInFullscreen
        -- No se renderiza cuando la página vista está en
        -- LayoutMode.fullscreen (ver surface ExperimentalCanvas).
}

-- Lienzo experimental: sólo en pantalla completa. La página posee el
-- viewport para HTML/p5.js propio; el skin no impone chrome.
surface ExperimentalCanvas {
    facing viewer: User
    context render: PageRender where mode = fullscreen

    exposes:
        render.page.content

    @guarantee ChromeSuppressed
        -- En fullscreen el skin suprime header, búsqueda, herramientas de
        -- usuario, sidebar, pie y panel de preferencias. El body de la
        -- página ocupa el viewport completo, salvo la afordancia de escape.

    @guidance
        -- Hoy el JS interactivo (p5.js) se inyecta vía MediaWiki:Common.js
        -- (script global del sitio): subóptimo y reconocido como deuda —
        -- ver pregunta abierta. El magic word es libre para cualquier
        -- editor; el riesgo de script NO está en el wikitexto de la página
        -- sino centralizado en Common.js (controlado por admins).
}

-- Afordancia mínima persistente: única pieza de chrome que sobrevive a
-- fullscreen. Garantiza no atrapar al usuario (WCAG, ARCHITECTURE.md §5).
surface EscapeAffordance {
    facing viewer: User
    context render: PageRender where mode = fullscreen

    exposes:
        render.page

    @guarantee AlwaysReachable
        -- Control discreto pero siempre visible y operable por teclado
        -- para volver/salir y, si procede, editar. Presente durante todo
        -- el modo fullscreen; nunca oculto tras hover-only.
}

-- Isotipo del sitio, enlazado a la portada. Decisión: AUTOCONTENIDO en el
-- skin (el asset canónico se versiona en el repo del skin, no en la wiki).
-- Estándar MediaWiki: el logo vive en $wgLogos (LocalSettings, nivel wiki)
-- y llega al skin por data-logos; el core NO tiene variante por tema. Aquí
-- se invierte por preferencia: el skin trae el isotipo y su adaptación
-- clara/oscura; $wgLogos, si está definido, actúa como override de
-- instalación.
surface SiteIsotype {
    facing viewer: User
    context session: ViewingSession where user = viewer

    exposes:
        session.active_theme

    @guarantee ThemeAdaptive
        -- Se muestra la variante del isotipo acorde a active_theme. El
        -- asset por defecto vive en el repo del skin; la adaptación
        -- clara/oscura es responsabilidad del skin (el core no la provee).

    @guarantee WikiOverride
        -- Si la instalación define $wgLogos (data-logos), ese valor
        -- sustituye al isotipo embebido; sin él, se usa el del skin.

    @guarantee LinksHome
        -- Enlaza a la portada (link-mainpage); comportamiento de MW core.

    @guarantee SuppressedInFullscreen
        -- Forma parte del chrome: ausente en LayoutMode.fullscreen.
}

-- Frontera código-a-código entre el skin y el host MediaWiki + sus
-- extensiones. Sin parte humana: el skin CUMPLE el contrato de fidelidad.
surface MediaWikiIntegration {
    exposes:
        RenderedDocument

    contracts:
        fulfils SkinRenderFidelity
        fulfils ChromeAccessibility
}

------------------------------------------------------------
-- Open Questions
------------------------------------------------------------

open question "Semántica exacta de 'en blanco' para una página de chrome (¿sólo espacios? ¿sólo comentarios HTML? ¿sólo enlaces de categoría?) — gobierna is_published de InterfaceFragment."

open question "Mecanismo definitivo de inyección de JS interactivo (p5.js) en páginas fullscreen: hoy es MediaWiki:Common.js global, subóptimo. Evaluar Widget curado, módulo ResourceLoader cargado sólo en páginas fullscreen, o assets por-página — sin habilitar JS arbitrario por editor."

open question "Fallback de fuente de chrome a main ns cuando el namespace dedicado no está realizado (InterfaceFragment.source_page / ManagedChrome.SourceResolution): ¿se mantiene como conveniencia permanente asumiendo que el contenido es de baja sensibilidad, o se retira una vez que declarar el namespace sea obligatorio en la instalación? Mientras exista, source_protected=false ⇒ RestrictChromeNamespaceWrites no aplica y la escritura del fragmento no está protegida."

open question "Devolución de foco al cerrar un panel emergente (TransientPanel): el patrón ARIA dialog canónico devuelve el foco al control que abrió el panel. La elicitación de 2026-05-24 dejó este punto fuera del contrato (se priorizaron Escape, scrim y trap). ¿Se añade como quinto invariante FocusReturnsToOpener, o se deja como responsabilidad opcional de la realización?"
